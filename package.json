{
  "name": "carvipix",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test:research-lab": "tsx --test app/research-lab/core/research-lab.test.ts app/research-lab/core/cdp-handshake.test.ts app/research-lab/core/cdp-export-adapter.test.ts app/research-lab/core/cdp-export-json.test.ts app/research-lab/core/proposal-export.test.ts app/research-lab/core/research-lab-v2.test.ts app/research-lab/core/knowledge-factory.test.ts",
    "coverage:research-lab": "node --import tsx --test --experimental-test-coverage app/research-lab/core/research-lab.test.ts app/research-lab/core/cdp-handshake.test.ts app/research-lab/core/cdp-export-adapter.test.ts app/research-lab/core/cdp-export-json.test.ts app/research-lab/core/proposal-export.test.ts app/research-lab/core/research-lab-v2.test.ts app/research-lab/core/knowledge-factory.test.ts",
    "test:engine": "tsx --test app/engine/core/engine.test.ts app/engine/core/intelligenceDirector.test.ts app/engine/core/researchProposalLoader.test.ts app/engine/core/evidenceEngine.test.ts app/engine/core/knowledgeEvolutionEngine.test.ts app/engine/core/quantOptimizationEngine.test.ts app/engine/core/quantValidationEngine.test.ts app/engine/core/tradingKnowledgeBase.test.ts app/engine/core/signalGenerationEngine.test.ts app/engine/core/signalProfitabilityValidation.test.ts app/engine/data/dataValidator.test.ts app/engine/warehouse/institutionalDataWarehouse.test.ts",
    "coverage:engine": "node --import tsx --test --experimental-test-coverage app/engine/core/engine.test.ts app/engine/core/intelligenceDirector.test.ts app/engine/core/researchProposalLoader.test.ts app/engine/core/evidenceEngine.test.ts app/engine/core/knowledgeEvolutionEngine.test.ts app/engine/core/quantOptimizationEngine.test.ts app/engine/core/quantValidationEngine.test.ts app/engine/core/tradingKnowledgeBase.test.ts app/engine/core/signalGenerationEngine.test.ts app/engine/core/signalProfitabilityValidation.test.ts app/engine/data/dataValidator.test.ts app/engine/warehouse/institutionalDataWarehouse.test.ts",
    "test:payments-state": "tsx --test app/backend/payments/core/state-machine.test.ts",
    "test:payments-phase2": "tsx --test app/backend/payments/core/payment-order-logic.test.ts app/backend/payments/core/provider-adapter-logic.test.ts",
    "test:payments-phase3": "tsx --test app/backend/payments/core/webhook-logic.test.ts app/backend/payments/core/provider-adapter-logic.test.ts",
    "test:payments-phase4": "tsx --test app/backend/payments/core/membership-activation-logic.test.ts app/backend/payments/core/webhook-logic.test.ts app/backend/payments/core/provider-adapter-logic.test.ts",
    "test:payments-phase5": "tsx --test app/backend/payments/core/email-outbox-logic.test.ts app/backend/notifications/templates.test.ts app/backend/payments/core/webhook-logic.test.ts app/backend/payments/core/provider-adapter-logic.test.ts",
    "test:payments-phase6": "tsx --test app/api/admin/payments/orders/query-helpers.test.ts app/admin/lib/payments-admin.test.ts",
    "test:payments-phase7": "tsx --test app/backend/payments/core/webhook-security-logic.test.ts app/api/admin/_shared/security.test.ts app/backend/payments/core/email-outbox-worker-queries.test.ts app/backend/payments/core/email-outbox-logic.test.ts app/backend/payments/core/webhook-logic.test.ts app/backend/payments/core/provider-adapter-logic.test.ts",
    "test:data-platform": "tsx --test app/backend/data-platform/core.test.ts app/backend/data-platform/official-source.test.ts app/api/datasets/route.test.ts",
    "test:system": "tsx --test --test-concurrency=1 app/backend/commercial/access-control.test.ts app/backend/commercial/plan-entitlements-store.test.ts app/backend/system/system-validation.test.ts app/backend/system/execution-runtime.test.ts app/backend/system/broker-sandbox.e2e.test.ts",
    "coverage:system": "node --import tsx --test --test-concurrency=1 --experimental-test-coverage app/backend/commercial/access-control.test.ts app/backend/commercial/plan-entitlements-store.test.ts app/backend/system/system-validation.test.ts app/backend/system/execution-runtime.test.ts app/backend/system/broker-sandbox.e2e.test.ts",
    "test:all": "npm run test:research-lab && npm run test:engine && npm run test:data-platform && npm run test:payments-state && npm run test:payments-phase2 && npm run test:payments-phase3 && npm run test:payments-phase4 && npm run test:payments-phase5 && npm run test:payments-phase6 && npm run test:payments-phase7 && npm run test:system",
    "worker:payments-email-once": "tsx app/backend/payments/core/email-outbox-worker-runner.ts",
    "lint": "eslint",
    "audit:architecture": "node scripts/audit-prohibited-engine-imports.mjs",
    "heavy:local": "node scripts/heavy-runner.mjs",
    "knowledge:bootstrap": "tsx scripts/bootstrap-official-knowledge.ts",
    "infra:up:local": "docker compose -f docker-compose.local.yml up -d --build",
    "infra:down:local": "docker compose -f docker-compose.local.yml down",
    "infra:heavy": "docker compose -f docker-compose.local.yml --profile heavy up heavy-worker",
    "deploy:local": "powershell -ExecutionPolicy Bypass -File scripts/deploy.ps1 -Environment local",
    "deploy:staging": "powershell -ExecutionPolicy Bypass -File scripts/deploy.ps1 -Environment staging",
    "deploy:prod": "powershell -ExecutionPolicy Bypass -File scripts/deploy.ps1 -Environment prod",
    "backup:local": "powershell -ExecutionPolicy Bypass -File scripts/backup-postgres.ps1 -Environment local",
    "backup:staging": "powershell -ExecutionPolicy Bypass -File scripts/backup-postgres.ps1 -Environment staging",
    "backup:prod": "powershell -ExecutionPolicy Bypass -File scripts/backup-postgres.ps1 -Environment prod",
    "restore:local": "powershell -ExecutionPolicy Bypass -File scripts/restore-postgres.ps1 -Environment local",
    "restore:staging": "powershell -ExecutionPolicy Bypass -File scripts/restore-postgres.ps1 -Environment staging",
    "restore:prod": "powershell -ExecutionPolicy Bypass -File scripts/restore-postgres.ps1 -Environment prod",
    "dr:drill:local": "powershell -ExecutionPolicy Bypass -File scripts/dr-drill.ps1 -Environment local",
    "dr:drill:staging": "powershell -ExecutionPolicy Bypass -File scripts/dr-drill.ps1 -Environment staging",
    "dr:drill:prod": "powershell -ExecutionPolicy Bypass -File scripts/dr-drill.ps1 -Environment prod"
  },
  "dependencies": {
    "framer-motion": "^12.42.2",
    "jszip": "^3.10.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.9",
    "nodemailer": "^9.0.3",
    "pg": "^8.13.1",
    "react": "19.2.4",
    "react-countup": "^6.5.3",
    "react-dom": "19.2.4",
    "recharts": "^3.9.1",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
